generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum Role{
  BUYER
  SELLER
  ADMIN
}
model User {
  id        String  @id @default(uuid())
  name      String
  email     String   @unique
  password  String 

  role Role @default(BUYER)
  createdAt DateTime @default(now())
}
